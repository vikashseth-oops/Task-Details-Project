    <a href="/" class="group flex items-center gap-2.5">
      <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-blue-600 text-sm font-bold text-white shadow-lg shadow-blue-600/20 transition group-hover:bg-blue-500">T</span>
      <span class="text-base font-semibold tracking-tight text-white sm:text-lg">Task Manager</span>
