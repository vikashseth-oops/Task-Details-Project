<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: task.title + ' — Task Manager' }) %>
</head>
<body class="min-h-screen bg-zinc-950 font-sans text-zinc-100 antialiased">
  <%- include('../partials/nav', { user, showBack: true }) %>

  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900/80 p-6 shadow-xl shadow-black/20 sm:p-10">
      <header class="mb-6 border-b border-zinc-800 pb-6 sm:mb-8 sm:pb-8">
        <p class="mb-2 text-xs font-medium uppercase tracking-wider text-zinc-500 sm:text-sm">Task</p>
        <h1 class="break-words text-2xl font-bold tracking-tight text-white sm:text-3xl lg:text-4xl"><%= task.title %></h1>
        <p class="mt-3 text-xs text-zinc-500 sm:text-sm">Created <%= new Date(task.createdAt).toLocaleDateString() %></p>
      </header>

      <div class="prose prose-invert max-w-none">
        <p class="whitespace-pre-wrap break-words text-base leading-relaxed text-zinc-300 sm:text-lg"><%= task.details %></p>
      </div>

      <footer class="mt-8 flex flex-col gap-3 border-t border-zinc-800 pt-6 sm:mt-10 sm:flex-row sm:items-center sm:justify-between sm:pt-8">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-zinc-700 bg-zinc-800/60 px-5 py-2.5 text-sm font-medium text-zinc-300 transition hover:border-zinc-600 hover:bg-zinc-800 hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Home
        </a>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="/tasks/<%= task._id %>/edit"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-zinc-800 px-5 py-2.5 text-sm font-medium text-zinc-300 transition hover:bg-zinc-700 hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit task
          </a>
          <form action="/tasks/<%= task._id %>/delete" method="post" onsubmit="return confirm('Delete this task?');">
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-red-900/50 bg-red-950/40 px-5 py-2.5 text-sm font-medium text-red-300 transition hover:bg-red-950 hover:text-red-200 sm:w-auto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Delete
            </button>
          </form>
        </div>
      </footer>
    </article>
  </main>
</body>
</html>
