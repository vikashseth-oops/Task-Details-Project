<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head', { title: 'Task Manager — Home' }) %>
</head>
<body class="min-h-screen bg-zinc-950 font-sans text-zinc-100 antialiased">
  <%- include('../partials/nav', { user }) %>

  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <header class="mb-8 sm:mb-12">
      <h1 class="text-2xl font-bold tracking-tight text-white sm:text-3xl lg:text-4xl">Your Tasks</h1>
      <p class="mt-2 max-w-xl text-sm text-zinc-400 sm:text-base">Create, view, and manage your personal tasks.</p>
    </header>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-6 rounded-xl border border-red-800/50 bg-red-950/50 px-4 py-3 text-sm text-red-300">
        <%= error %>
      </div>
    <% } %>

    <section class="mb-10 sm:mb-14">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900/80 p-5 shadow-xl shadow-black/20 sm:p-8">
        <h2 class="mb-5 text-lg font-semibold text-white sm:text-xl">Create a new task</h2>
        <form action="/tasks" method="post" class="space-y-4">
          <div>
            <label for="title" class="mb-1.5 block text-sm font-medium text-zinc-400">Title</label>
            <input
              id="title"
              class="block w-full rounded-xl border border-zinc-700 bg-zinc-800 px-4 py-3 text-white placeholder-zinc-500 transition outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 sm:px-5"
              type="text"
              placeholder="Enter task title"
              name="title"
              required
            >
          </div>
          <div>
            <label for="details" class="mb-1.5 block text-sm font-medium text-zinc-400">Details</label>
            <textarea
              id="details"
              class="block min-h-32 w-full resize-y rounded-xl border border-zinc-700 bg-zinc-800 px-4 py-3 text-white placeholder-zinc-500 transition outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 sm:min-h-36 sm:px-5 sm:py-4"
              placeholder="Write your task details here..."
              name="details"
              required
            ></textarea>
          </div>
          <button
            type="submit"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-600/25 transition hover:bg-blue-500 active:scale-[0.98] sm:w-auto"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Create Task
          </button>
        </form>
      </div>
    </section>

    <section>
      <div class="mb-5 flex items-center justify-between gap-4">
        <h2 class="text-lg font-semibold text-white sm:text-xl">All Tasks</h2>
        <% if (tasks.length > 0) { %>
          <span class="rounded-full bg-zinc-800 px-3 py-1 text-xs font-medium text-zinc-400 sm:text-sm"><%= tasks.length %> total</span>
        <% } %>
      </div>

      <% if (tasks.length > 0) { %>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
          <% tasks.forEach(function(task) { %>
            <article class="group flex flex-col rounded-2xl border border-zinc-800 bg-zinc-900/60 p-5 transition hover:border-zinc-700 hover:bg-zinc-900 hover:shadow-lg hover:shadow-black/20 sm:p-6">
              <h3 class="line-clamp-2 text-lg font-semibold tracking-tight text-white sm:text-xl"><%= task.title %></h3>
              <p class="mt-2 line-clamp-3 text-sm text-zinc-500"><%= task.details %></p>
              <div class="mt-auto flex flex-col gap-2 pt-5 sm:flex-row sm:items-center sm:justify-between">
                <a
                  class="inline-flex items-center gap-1 text-sm font-medium text-blue-400 transition hover:text-blue-300"
                  href="/tasks/<%= task._id %>"
                >
                  Read more
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
                <a
                  class="inline-flex items-center justify-center rounded-lg border border-zinc-700 px-3 py-1.5 text-xs font-medium text-zinc-400 transition hover:border-zinc-600 hover:bg-zinc-800 hover:text-zinc-200 sm:text-sm"
                  href="/tasks/<%= task._id %>/edit"
                >
                  Edit task
                </a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-zinc-800 bg-zinc-900/40 px-6 py-16 text-center sm:py-20">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-800 text-zinc-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-zinc-300">No tasks yet</h3>
          <p class="mt-1 max-w-sm text-sm text-zinc-500">Create your first task using the form above.</p>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
